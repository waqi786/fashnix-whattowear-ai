<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinder"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Elite Scan Visuals -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_bottom_overlay"
        android:alpha="0.5" />

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/cameraToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#D9050505"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@color/text_primary"
        app:title="Smart Scan"
        app:titleCentered="true"
        app:titleTextColor="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/scanLine"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/primary"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/alignText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ALIGN GARMENT WITHIN FRAME"
        android:textColor="@color/white"
        android:textSize="10sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.2"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toTopOf="@id/controlsContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Controls: Positioned higher to avoid system nav overlap -->
    <LinearLayout
        android:id="@+id/controlsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="60dp"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/galleryButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_glass"
            android:src="@drawable/ic_gallery"
            app:tint="@color/white" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/captureButton"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginHorizontal="44dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="42dp"
            app:strokeWidth="5dp"
            app:strokeColor="@color/primary">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="5dp"
                android:background="@drawable/bg_circle_solid"
                android:backgroundTint="@color/black"
                android:alpha="0.1" />
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/switchCameraButton"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_glass"
            android:src="@drawable/ic_switch_camera"
            app:tint="@color/white" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
