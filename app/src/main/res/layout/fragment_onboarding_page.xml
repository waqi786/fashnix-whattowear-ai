<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="false">

    <!-- Premium Decorative Elements (Luxury Glows) -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_circle_glass"
        android:alpha="0.15"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-150dp"
        android:layout_marginEnd="-150dp" />

    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:background="@drawable/bg_circle_glass"
        android:alpha="0.1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="-100dp"
        android:layout_marginStart="-100dp" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieAnimation"
        android:layout_width="match_parent"
        android:layout_height="380dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/fashion_loading"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="60dp"
        android:scaleType="centerInside" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        app:layout_constraintTop_toBottomOf="@id/lottieAnimation"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="120dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ELITE STYLE\nINTELLIGENCE"
            android:textColor="@color/white"
            android:textSize="42sp"
            android:lineHeight="44sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02" />

        <View
            android:id="@+id/separator"
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:background="@color/primary"
            android:layout_marginTop="20dp" />

        <TextView
            android:id="@+id/subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your wardrobe, decoded by AI. Experience personalized styling that evolves with your identity."
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="4dp"
            android:alpha="0.8" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>