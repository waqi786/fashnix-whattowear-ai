<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/LuxuryCardStyle"
    android:layout_width="160dp"
    android:layout_height="180dp"
    android:layout_margin="8dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="24dp"
    app:strokeWidth="1dp"
    app:strokeColor="#12FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:background="@drawable/ring_gradient"
        android:backgroundTint="#08FFFFFF">

        <!-- Minimalist Icon Wrapper -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconWrapper"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:cardBackgroundColor="#10FFFFFF"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/insightIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_chart"
                app:tint="@color/primary" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Large Insight Value -->
        <TextView
            android:id="@+id/insightValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:letterSpacing="-0.04"
            tools:text="84%"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iconWrapper" />

        <!-- Descriptive Title -->
        <TextView
            android:id="@+id/insightTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="sans-serif-bold"
            android:textColor="@color/primary_light"
            android:textSize="10sp"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            tools:text="VERSATILITY"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/insightValue" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>