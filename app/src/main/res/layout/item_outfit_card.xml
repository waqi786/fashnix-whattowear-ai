<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/surface_variant"
    app:cardCornerRadius="32dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border_glass">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- High-Fashion Imagery -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/itemImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_wardrobe_placeholder"
            app:shapeAppearanceOverlay="@style/RoundedImageView" />

        <!-- Elite Vignette Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="@drawable/gradient_bottom_overlay"
            app:layout_constraintBottom_toBottomOf="parent" />

        <ImageButton
            android:id="@+id/favoriteButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="20dp"
            android:background="@drawable/bg_circle_glass"
            android:backgroundTint="#4D000000"
            android:src="@drawable/ic_heart"
            android:padding="12dp"
            app:tint="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Premium Details Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/itemBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="FASHNIX PRESTIGE"
                android:textColor="@color/primary"
                android:textSize="10sp"
                android:letterSpacing="0.25"
                android:fontFamily="sans-serif-black"
                android:textAllCaps="true" />

            <TextView
                android:id="@+id/itemName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                tools:text="Midnight Velvet Blazer"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0"
                android:ellipsize="end"
                android:maxLines="2" />

            <TextView
                android:id="@+id/itemCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="GALA EDITION"
                android:textColor="@color/success"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <View
                android:layout_width="40dp"
                android:layout_height="2dp"
                android:background="@color/primary"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/itemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="4 WEARS"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
