rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read, update, delete: if isOwner(userId);

      match /chatHistory/{messageId} {
        allow read, write, delete: if isOwner(userId);
      }

      match /scans/{scanId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    match /wardrobe/{itemId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /planner/{userId}/outfits/{outfitId} {
      allow read, write, delete: if isOwner(userId);
    }

    match /familyGroups/{groupId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid;
      allow read, update, delete: if signedIn()
        && request.auth.uid in resource.data.memberIds;
    }
  }
}
