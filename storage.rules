rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /wardrobe/{userId}/{fileName} {
      allow read, write, delete: if signedIn() && request.auth.uid == userId;
    }

    match /scans/{userId}/{fileName} {
      allow read, write, delete: if signedIn() && request.auth.uid == userId;
    }

    match /profiles/{userId}/{fileName} {
      allow read, write, delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
